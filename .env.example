# =============================================
# NutriAI 运行时环境变量示例（Gitee Go + 腾讯云 TCR 自动部署）
# =============================================
# 说明：
# 1. 复制为 .env 后填入实际值
# 2. Gitee Go 工作流会构建时间戳镜像并推送到腾讯云 TCR
# 3. Gitee Go 部署阶段会自动更新 IMAGE_TAG 与 TCR 相关字段
# =============================================

# ---------- 腾讯云 TCR ----------
TCR_REGISTRY=ccr.ccs.tencentyun.com
TCR_NAMESPACE=your_tcr_namespace
BACKEND_IMAGE_REPO=nutriai-backend
FRONTEND_IMAGE_REPO=nutriai-frontend
REDIS_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/redis:6.0-alpine
IMAGE_TAG=20260101000000

# ---------- 旧库迁移源库（仅迁移脚本/开发使用，后端生产禁止使用） ----------
SOURCE_DB_HOST=bj-cynosdbmysql-grp-old-xxxxxxxx.sql.tencentcdb.com
SOURCE_DB_PORT=3306
SOURCE_DB_NAME=nutriai
SOURCE_DB_USERNAME=your_source_db_username
SOURCE_DB_PASSWORD=your_source_db_password

# ---------- 云数据库（腾讯云 MySQL，后端生产强制走内网） ----------
DB_HOST_NEI=10.0.0.10
DB_PORT_NEI=3306
DB_NAME=nutriai
DB_USERNAME=your_target_db_username
DB_PASSWORD=your_target_db_password
DB_USE_SSL=false
DB_REQUIRE_SSL=false

# ---------- 开发环境外网地址（仅本地开发使用，不会注入生产后端） ----------
DB_HOST=bj-cynosdbmysql-grp-new-xxxxxxxx.sql.tencentcdb.com
DB_PORT=3306

# ---------- Redis ----------
REDIS_PASSWORD=your_redis_password

# ---------- JWT ----------
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long_for_hs512

# ---------- AI ----------
AI_API_KEY=sk-your_ai_api_key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_NAME=qwen3.5-122b-a10b
AI_DIET_PLAN_MODEL=qwen3.5-flash

# ---------- COS ----------
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-beijing
COS_BUCKET=your-bucket-name
COS_URL=https://your-bucket-name.cos.ap-beijing.myqcloud.com
COS_CUSTOM_DOMAIN=

# ---------- 邮件 ----------
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_NICKNAME=NutriAI健康饮食助手

# ---------- 腾讯云短信（可选） ----------
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_SDK_APP_ID=
SMS_SIGN_NAME=NutriAI
SMS_TEMPLATE_ID=

# ---------- 其他可选能力 ----------
BAIDU_AI_APP_ID=
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=
EPAY_MERCHANT_ID=
EPAY_MERCHANT_KEY=
EPAY_API_URL=
EPAY_SUBMIT_URL=
EPAY_MAPI_URL=
EPAY_NOTIFY_URL=
EPAY_RETURN_URL=

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=https://your-domain.com
